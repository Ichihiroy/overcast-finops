# Copy to terraform.tfvars (gitignored) and fill in. NEVER commit terraform.tfvars.
subscription_id = "00000000-0000-0000-0000-000000000000"

team        = "thelocals" # team slug — keeps our resource names from colliding with other teams'
project     = "ironhack"
environment = "prod"
location    = "westeurope"

# sql_admin_login       = "sqladminuser"
# system_node_vm_size   = "Standard_D2s_v5"
# user_node_vm_size     = "Standard_D4s_v5"
# user_node_max_count   = 6

# GitOps (Argo CD) — see docs/adr/0008. In CI these arrive as TF_VAR_* from
# the FRONTEND_HOST_* repo variables; set them here only for local plans.
# gitops_repo_url          = "https://github.com/Ichihiroy/ironhack-final.git"
# gitops_revision          = "main"
# frontend_host_staging    = "staging.example.com"
# frontend_host_production = "app.example.com"

# Azure OpenAI (optional — enables the AI assistant). In CI the key comes from
# the AZURE_OPENAI_API_KEY repo SECRET; endpoint/deployment from repo variables.
# azure_openai_endpoint    = "https://<resource>.openai.azure.com/"
# azure_openai_deployment  = "gpt-5.6-luna"
# azure_openai_api_version = "2024-06-01"
# azure_openai_api_key     = "<never commit this>"
